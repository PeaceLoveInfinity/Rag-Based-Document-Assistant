```gitignore
# =========================================================
# PYTHON CACHE / COMPILED FILES
# =========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# =========================================================
# VIRTUAL ENVIRONMENTS
# =========================================================
.env
.envrc
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# =========================================================
# ENVIRONMENT VARIABLE EXAMPLE FILES
# =========================================================
# Keep .env.example tracked
!.env.example

# =========================================================
# DISTRIBUTION / PACKAGING
# =========================================================
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
share/python-wheels/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =========================================================
# PYINSTALLER
# =========================================================
*.manifest
*.spec

# =========================================================
# INSTALLER LOGS
# =========================================================
pip-log.txt
pip-delete-this-directory.txt

# =========================================================
# TESTING / COVERAGE
# =========================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/

# =========================================================
# JUPYTER / IPYTHON
# =========================================================
.ipynb_checkpoints
profile_default/
ipython_config.py

# =========================================================
# TYPE CHECKERS / LINTERS
# =========================================================
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# =========================================================
# DJANGO / FLASK / FASTAPI
# =========================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache

# =========================================================
# DOCUMENTATION
# =========================================================
docs/_build/
site/

# =========================================================
# IDE / EDITOR FILES
# =========================================================
.vscode/
.idea/
.spyderproject
.spyproject
.ropeproject
tempCodeRunnerFile.py

# =========================================================
# OS FILES
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# DOCKER
# =========================================================
*.tar

# =========================================================
# PDFS / USER UPLOADS
# =========================================================
*.pdf

# =========================================================
# STREAMLIT
# =========================================================
.streamlit/secrets.toml

# =========================================================
# PYTHON PACKAGE MANAGERS
# =========================================================
.pdm-python
.pdm-build/
.pixi/
__pypackages__/

# =========================================================
# CELERY / REDIS / RABBITMQ
# =========================================================
celerybeat-schedule
celerybeat.pid
*.rdb
*.aof
*.pid
mnesia/
rabbitmq/
rabbitmq-data/

# =========================================================
# MARIMO
# =========================================================
marimo/_static/
marimo/_lsp/
__marimo__/

# =========================================================
# AZURE / DEPLOYMENT TEMP FILES
# =========================================================
.azure/
```